{
    "name": "php-soap/engine",
    "description": "SOAP engine design",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Soap\\Engine\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Toon Verwerft",
            "email": "toonverwerft@gmail.com"
        }
    ],
    "require": {
        "php": "~8.4.0 || ~8.5.0",
        "php-standard-library/dict": "^6.1",
        "php-standard-library/foundation": "^6.1",
        "php-standard-library/option": "^6.1",
        "php-standard-library/type": "^6.1",
        "php-soap/xml": "^1.10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "SoapTest\\Engine\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.3 || ^13.0",
        "php-standard-library/psalm-plugin": "^2.2",
        "vimeo/psalm": "^6.13",
        "php-cs-fixer/shim": "^3.88"
    }
}
